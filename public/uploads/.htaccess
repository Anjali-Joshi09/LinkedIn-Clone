# Block PHP execution in uploads — prevents Remote Code Execution
php_flag engine off
Options -ExecCGI -Indexes

# Treat PHP-like extensions as plain text
AddType text/plain .php .php3 .php4 .php5 .php7 .phtml .shtml .phar

# Deny direct HTTP access to any PHP-like file as a fallback
<FilesMatch "\.(php|php3|php4|php5|php7|phtml|shtml|phar)$">
    Require all denied
</FilesMatch>